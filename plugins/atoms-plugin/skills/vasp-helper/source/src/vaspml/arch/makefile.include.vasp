##############################################
# This makefile.include template is used when
# VASPml is built as part of a VASP build.
#
# Do not edit this file unless you know what
# you are doing.
##############################################

# ------------------------------------------
# Get variables from VASP's makefile.include
# ------------------------------------------
include ../../../makefile.include

# --------
# Compiler
# --------
CXX             = $(CXX_ML)

# --------------
# Compiler flags
# --------------
CXXFLAGS        = $(CXXFLAGS_ML) $(VASP_TARGET_CPU)
## TODO: Temporary fix to convert flag for Fortran compiler.
#empty :=
#space := $(empty) $(empty)
#CXXFLAGS        = $(CXXFLAGS_ML) $(subst -arch$(space)HASWELL,-march=core-avx2,$(VASP_TARGET_CPU))

# -------------------
# Include directories
# -------------------
INCLUDE         = $(INCLUDE_ML)

# ------------
# Preprocessor
# ------------
# We require some modifications for the CPP_OPTIONS given from VASP:
# 1. Not allowed to define MPI macro, Intel oneAPI MPI has a namespace with this name.
# 2. Redefining _OPENMP causes errors with "-Wall -pedantic-errors".
# 3. Not allowed to define HOST macro, Intel oneAPI MPI is using this.
CPP_OPTIONS    := $(filter-out -DMPI -D_OPENMP -DHOST%,$(CPP_OPTIONS))

# --------------------
# Dependency generator
# --------------------
CPP_DEP        ?= $(CXX)

# --------------
# Archiving tool
# --------------
AR              = ar
ARFLAGS         = rcs

# ----------------
# Additional make options
# ----------------
MAKE_OPTIONS   += --no-color
MAKE_OPTIONS   += --no-logo
